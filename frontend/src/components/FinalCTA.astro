---

<section class="final-cta-section section hero-pattern-gradient">
  <div class="container">
    <div class="glass-container">
      <h2>Проверить уровень устойчивости вашей команды</h2>
      <p class="final-cta-text">
        Обсудить задачи компании напрямую
      </p>
      <div class="final-cta-buttons">
        <a href="/assessment" class="button-primary">Проверить уровень устойчивости</a>
        <a href="/contact" class="button-secondary">Обсудить задачи напрямую</a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    padding: var(--spacing-3xl) 0;
  }

  @media (min-width: 768px) {
    .final-cta-section {
      padding: var(--spacing-4xl) 0;
    }
  }

  .final-cta-section .glass-container {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .final-cta-section h2 {
    color: #fff;
    margin-bottom: var(--spacing-lg);
    font-size: var(--text-xl);
  }

  @media (min-width: 768px) {
    .final-cta-section h2 {
      font-size: var(--text-2xl);
    }
  }

  @media (min-width: 1024px) {
    .final-cta-section h2 {
      font-size: var(--text-3xl);
    }
  }

  .final-cta-text {
    color: rgba(255, 255, 255, 0.9);
    font-size: var(--text-base);
    margin-bottom: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .final-cta-text {
      font-size: var(--text-lg);
    }
  }

  .final-cta-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    align-items: center;
  }

  @media (min-width: 768px) {
    .final-cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  .final-cta-buttons .button-secondary {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }

  .final-cta-buttons .button-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
  }
</style>
