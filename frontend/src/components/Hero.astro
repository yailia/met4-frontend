---
import { getImage } from "astro:assets";
import heroImage from "../assets/hero-image.png";

// Генерируем оптимизированное изображение для hero
const heroImageOptimized = await getImage({
  src: heroImage,
  widths: [300, 400, 500, 600],
  format: "webp",
  quality: "high",
  fit: "cover",
});
---

<section class="hero section">
  <div class="container">
    <div class="hero-content">
      <div class="glass-container">
        <h1>
          <span class="hero-title-strong">Устойчивость</span> персонала как KPI
          бизнеса
        </h1>
        <p class="hero-subtitle">
          Повышаем устойчивость команд измеримо и в срок — по проверенной методологии
        </p>
        <div class="hero-cta">
          <a href="/assessment" class="button-primary"
            >Оценить устойчивость команды за 15 минут</a
          >
          <a href="/webinar" class="button-secondary">Как это работает</a>
        </div>
      </div>

      <div class="hero-speakers">
        <div class="hero-decorative-ball"></div>
        <img 
          src={heroImageOptimized.src} 
          srcset={heroImageOptimized.srcSet.attribute}
          alt="Hero изображение" 
        />
        <div class="hero-speakers-caption">
          <div class="hero-speakers-title">Эксперты по устойчивости команд</div>
          <div class="hero-speakers-note">10+ лет практики в корпоративных командах</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background-color: #24272e;
    background-image: 
      radial-gradient(600px 400px at 30% 40%, rgba(150, 105, 216, 0.18), transparent 65%),
      linear-gradient(to bottom, rgba(36, 39, 46, 0.97), #24272e);
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 70vh;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      min-height: 80vh;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-xl);
    width: 100%;
  }

  @media (max-width: 767px) {
    .hero .glass-container {
      background: transparent;
      border: none;
      backdrop-filter: none;
      padding: 0;
    }

    .hero-content {
      gap: var(--spacing-lg);
    }

    .hero .glass-container {
      order: 1;
    }

    .hero-speakers {
      order: 2;
      width: 100%;
      max-width: none;
    }

    .hero-speakers img {
      border-radius: 0;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      gap: var(--spacing-3xl);
    }
  }

  @media (min-width: 768px) {
    .hero-content {
      flex-direction: row;
    }
  }

  .hero .glass-container {
    flex: 1;
    padding: var(--spacing-md) var(--spacing-lg);
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
  }

  @media (min-width: 768px) {
    .hero .glass-container {
      flex: 1.2;
      max-width: none;
    }
  }

  .hero h1 {
    color: #fff;
    margin: 0 0 var(--spacing-sm) 0;
    font-size: var(--text-2xl);
    line-height: 1.06;
    letter-spacing: -0.01em;
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: var(--text-3xl);
      line-height: 1.04;
    }
  }

  @media (min-width: 1024px) {
    .hero h1 {
      font-size: var(--text-4xl);
      line-height: 1.02;
    }
  }

  @media (max-width: 767px) {
    .hero h1 {
      font-weight: 700;
      line-height: 1.08;
    }
  }

  .hero-title-strong {
    font-weight: 700;
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.84);
    font-size: var(--text-base);
    margin: 0 0 var(--spacing-md) 0;
    line-height: var(--lh-normal);
  }

  @media (max-width: 767px) {
    .hero-subtitle {
      font-size: var(--text-sm);
      line-height: 1.4;
    }
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: var(--text-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero-subtitle {
      font-size: var(--text-xl);
    }
  }

  @media (min-width: 1024px) {
    .hero .glass-container {
      padding: var(--spacing-lg) var(--spacing-xl);
    }
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    align-items: stretch;
  }

  @media (max-width: 767px) {
    .hero-cta {
      gap: var(--spacing-sm);
    }

    .hero-cta .button-primary {
      width: 100%;
      min-height: 52px;
      justify-content: center;
    }

    .hero-cta .button-secondary {
      background: transparent;
      border: none;
      padding: 0;
      min-height: auto;
      width: fit-content;
      color: rgba(255, 255, 255, 0.85);
      text-decoration: underline;
    }
  }

  @media (min-width: 768px) {
    .hero-cta {
      flex-direction: row;
    }
  }

  .hero-cta .button-secondary {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
  }

  .hero-cta .button-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: #fff;
  }

  .hero-speakers {
    flex: 1;
    position: relative;
  }

  @media (min-width: 768px) {
    .hero-speakers {
      flex: 0.8;
      max-width: none;
    }
  }

  .hero-speakers img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    position: relative;
    z-index: 1;
  }

  .hero-decorative-ball {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      rgba(150, 105, 216, 0.4) 0%,
      rgba(63, 143, 107, 0.3) 40%,
      rgba(217, 164, 65, 0.2) 70%,
      transparent 100%
    );
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    .hero-decorative-ball {
      width: 400px;
      height: 400px;
      filter: blur(80px);
    }
  }

  @media (min-width: 1024px) {
    .hero-decorative-ball {
      width: 500px;
      height: 500px;
      filter: blur(100px);
    }
  }

  .hero-speakers-caption {
    margin-top: var(--spacing-sm);
    color: rgba(255, 255, 255, 0.9);
  }

  @media (min-width: 768px) {
    .hero-speakers-caption {
      position: absolute;
      bottom: var(--spacing-md);
      left: 50%;
      transform: translateX(-50%);
      width: calc(100% - var(--spacing-lg) * 2);
      max-width: 90%;
      margin-top: 0;
      padding: var(--spacing-md) var(--spacing-lg);
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 18px;
      text-align: center;
      z-index: 2;
    }
  }

  .hero-speakers-title {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .hero-speakers-note {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.72);
  }

  @media (min-width: 768px) {
    .hero-speakers-title {
      font-size: var(--text-lg);
    }

    .hero-speakers-note {
      font-size: var(--text-base);
    }
  }

  @media (max-width: 767px) {
    .hero-speakers-caption {
      margin-top: var(--spacing-md);
    }

    .hero-speakers-title {
      font-size: var(--text-base);
    }

    .hero-speakers-note {
      font-size: var(--text-sm);
    }
  }
</style>
