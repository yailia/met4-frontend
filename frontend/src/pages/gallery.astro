---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Галерея - МЭТЧ" description="Фото мероприятий, процессов работы и живых людей - реальные подтверждения нашей работы.">
  <main>
    <section class="gallery-hero section">
      <div class="container">
        <h1>Галерея</h1>
        <p class="gallery-intro">
          Реальные люди, реальные процессы, реальные результаты
        </p>
      </div>
    </section>

    <section class="gallery-content section">
      <div class="container">
        <div class="gallery-grid grid grid-mobile">
          <div class="gallery-item">
            <div class="gallery-placeholder">
              <p>Фото мероприятий</p>
            </div>
            <p class="gallery-caption">Тренинги и семинары</p>
          </div>
          <div class="gallery-item">
            <div class="gallery-placeholder">
              <p>Процесс работы</p>
            </div>
            <p class="gallery-caption">Работа с командами</p>
          </div>
          <div class="gallery-item">
            <div class="gallery-placeholder">
              <p>Живые люди</p>
            </div>
            <p class="gallery-caption">Участники программ</p>
          </div>
          <div class="gallery-item">
            <div class="gallery-placeholder">
              <p>Мероприятия</p>
            </div>
            <p class="gallery-caption">События и встречи</p>
          </div>
          <div class="gallery-item">
            <div class="gallery-placeholder">
              <p>Фрагменты процессов</p>
            </div>
            <p class="gallery-caption">Рабочие сессии</p>
          </div>
          <div class="gallery-item">
            <div class="gallery-placeholder">
              <p>Результаты</p>
            </div>
            <p class="gallery-caption">Достижения команд</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .gallery-hero {
    background: var(--color-bg);
    text-align: center;
  }

  .gallery-hero h1 {
    margin-bottom: var(--spacing-lg);
    font-size: var(--text-2xl);
  }

  @media (min-width: 768px) {
    .gallery-hero h1 {
      font-size: var(--text-3xl);
    }
  }

  @media (min-width: 1024px) {
    .gallery-hero h1 {
      font-size: var(--text-4xl);
    }
  }

  .gallery-intro {
    max-width: 700px;
    margin: 0 auto;
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .gallery-intro {
      font-size: var(--text-lg);
    }
  }

  .gallery-content {
    background: var(--color-surface);
  }

  .gallery-grid {
    gap: var(--spacing-lg);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-xl);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-item {
    border-radius: 16px;
    overflow: hidden;
  }

  .gallery-placeholder {
    background: var(--color-bg);
    border: 2px dashed var(--color-border);
    padding: var(--spacing-3xl);
    text-align: center;
    color: var(--color-text-muted);
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .gallery-placeholder {
      min-height: 300px;
    }
  }

  @media (min-width: 1024px) {
    .gallery-placeholder {
      min-height: 350px;
    }
  }

  .gallery-caption {
    padding: var(--spacing-md);
    text-align: center;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    background: var(--color-surface);
  }
</style>
