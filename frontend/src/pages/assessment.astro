---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.svelte';
import AssessmentTest from '../components/AssessmentTest.svelte';
---

<BaseLayout title="Оценка устойчивости команды - МЭТЧ" description="Пройдите диагностику устойчивости вашей команды. 5-10 минут, бесплатно.">
  <main>
    <section class="assessment-hero section">
      <div class="container">
        <h1>Оценка устойчивости команды</h1>
        <p class="assessment-intro">
          Пройдите опросник вовлеченности персонала Q12 от института Гэллапа.
          Это займет 5-10 минут и поможет оценить текущее состояние вашей команды.
        </p>
        <div class="assessment-benefits">
          <h3>Что вы получите:</h3>
          <ul>
            <li>Оценку уровня вовлеченности команды</li>
            <li>Выявление зон риска и возможностей</li>
            <li>Рекомендации по улучшению</li>
            <li>Обсуждение результатов с экспертом</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="assessment-form-section section">
      <div class="container">
        <ContactForm client:load />
      </div>
    </section>

    <section class="assessment-test-section section">
      <div class="container">
        <AssessmentTest client:load />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .assessment-hero {
    background: var(--color-bg);
    text-align: center;
  }

  .assessment-hero h1 {
    margin-bottom: var(--spacing-lg);
    font-size: var(--text-2xl);
  }

  @media (min-width: 768px) {
    .assessment-hero h1 {
      font-size: var(--text-3xl);
    }
  }

  @media (min-width: 1024px) {
    .assessment-hero h1 {
      font-size: var(--text-4xl);
    }
  }

  .assessment-intro {
    max-width: 700px;
    margin: 0 auto var(--spacing-2xl);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--lh-loose);
  }

  @media (min-width: 768px) {
    .assessment-intro {
      font-size: var(--text-lg);
    }
  }

  .assessment-benefits {
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
    background: var(--color-surface);
    padding: var(--spacing-xl);
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
  }

  .assessment-benefits h3 {
    margin-bottom: var(--spacing-md);
    text-align: center;
  }

  .assessment-benefits ul {
    list-style: none;
    padding: 0;
  }

  .assessment-benefits li {
    padding: var(--spacing-sm) 0;
    padding-left: var(--spacing-xl);
    position: relative;
    color: var(--color-text-secondary);
  }

  .assessment-benefits li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--fw-bold);
  }

  .assessment-form-section {
    background: var(--color-bg);
    background-image:
      linear-gradient(
        rgba(79, 127, 106, 0.06) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(79, 127, 106, 0.06) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
  }

  .assessment-test-section {
    background: var(--color-bg);
    background-image: repeating-linear-gradient(
      135deg,
      rgba(79, 127, 106, 0.05) 0,
      rgba(79, 127, 106, 0.05) 1px,
      transparent 1px,
      transparent 64px
    );
  }
</style>
