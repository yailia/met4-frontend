---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.svelte';
---

<BaseLayout title="Контакты - МЭТЧ" description="Свяжитесь с нами для обсуждения задач вашей компании.">
  <main>
    <section class="contact-hero section">
      <div class="container">
        <h1>Обсудить задачи компании напрямую</h1>
        <p class="contact-intro">
          Свяжитесь с нами, чтобы обсудить, как мы можем помочь повысить устойчивость и эффективность вашей команды
        </p>
      </div>
    </section>

    <section class="contact-form-section section section-grid-bg">
      <div class="container">
        <ContactForm client:load />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-hero {
    background: var(--color-bg);
    text-align: center;
    padding: var(--spacing-3xl) 0;
  }

  .contact-hero h1 {
    margin-bottom: var(--spacing-lg);
    font-size: var(--text-2xl);
  }

  @media (min-width: 768px) {
    .contact-hero h1 {
      font-size: var(--text-3xl);
    }
  }

  @media (min-width: 1024px) {
    .contact-hero h1 {
      font-size: var(--text-4xl);
    }
  }

  .contact-intro {
    max-width: 700px;
    margin: 0 auto;
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--lh-loose);
  }

  @media (min-width: 768px) {
    .contact-intro {
      font-size: var(--text-lg);
    }
  }

  .contact-form-section {
    padding: var(--spacing-3xl) 0;
  }
</style>
